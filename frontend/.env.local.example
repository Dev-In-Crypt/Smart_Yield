NEXT_PUBLIC_VAULT_MANAGER_ADDRESS=0x...
# Local EVM Minitia baseline (from hackathon docs)
# 1) Run `weave init` and choose L1: initiation-2, VM: EVM, chain_id: bank-1 (or your own)
# 2) Get EVM chain id from your local node:
#    cast chain-id --rpc-url http://localhost:8545
NEXT_PUBLIC_CHAIN_ID=245901640121214
NEXT_PUBLIC_RPC_URL=http://localhost:8545

# InterwovenKit / Bridge config
NEXT_PUBLIC_INTERWOVEN_CHAIN_ID=local-rollup-1
NEXT_PUBLIC_INTERWOVEN_RPC_URL=http://localhost:26657
NEXT_PUBLIC_INTERWOVEN_REST_URL=http://localhost:1317
NEXT_PUBLIC_INTERWOVEN_INDEXER_URL=http://localhost:8080
NEXT_PUBLIC_INTERWOVEN_BRIDGE_DENOM=uinit

# Server-side only — for API routes reading rebalance history
DATABASE_URL=postgresql://user:password@localhost:5432/vaultdb
