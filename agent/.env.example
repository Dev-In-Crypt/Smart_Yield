# ── Chain ─────────────────────────────────────────────────────────────────────
# cabal  (chain ID 2630341494499703): https://jsonrpc-cabal-1.anvil.asia-southeast.initia.xyz
# yominet (chain ID 428962654539583): https://jsonrpc-yominet-1.anvil.asia-southeast.initia.xyz
RPC_URL=https://jsonrpc-cabal-1.anvil.asia-southeast.initia.xyz

# ── Contract addresses (fill from deployments.json after forge script) ────────
VAULT_MANAGER_ADDRESS=0x...
KEEPER_EXECUTOR_ADDRESS=0x...

# ── Agent wallet ──────────────────────────────────────────────────────────────
# This key's public address must match AGENT_SIGNER_ADDRESS in KeeperExecutor
KEEPER_PRIVATE_KEY=0x...

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/vaultdb

# ── Tuning ────────────────────────────────────────────────────────────────────
CRON_INTERVAL_MINUTES=30
# Skip rebalance if no strategy delta exceeds this (basis points)
MIN_REBALANCE_THRESHOLD_BPS=50
